# AWS Configuration
# Get these from AWS Console: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=ap-south-1

# S3 Bucket
# Your S3 bucket name for storing audio/documents
S3_BUCKET=your-bucket-name

# DynamoDB Tables
# Your DynamoDB table names
SESSIONS_TABLE=user-sessions
USERS_TABLE=user-profiles
SCHEMES_CACHE_TABLE=schemeuser

# IndicTrans2 Server (Optional)
# If you deployed IndicTrans2 on EC2, add the URL here
# Otherwise, leave empty to use fallback translation
INDICTRANS2_URL=http://YOUR_EC2_PUBLIC_IP:5001

# SNS Topic ARN (Optional - for SMS notifications)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:your-account-id:your-topic-name

# Bedrock Region
BEDROCK_REGION=us-east-1

# Data Region (for other AWS services)
DATA_REGION=ap-south-1

# ============================================
# IMPORTANT: Never commit the actual .env file!
# ============================================
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. The .env file is in .gitignore and won't be pushed to GitHub
# 4. For deployment, add these as environment variables in Render/Heroku dashboard
