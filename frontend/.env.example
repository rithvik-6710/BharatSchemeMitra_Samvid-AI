# Frontend Environment Variables

# Backend API URL
# For local development: http://localhost:5000
# For production: Your deployed backend URL
REACT_APP_API_URL=http://localhost:5000

# ============================================
# IMPORTANT: Never commit the actual .env file!
# ============================================
# 1. Copy this file to .env
# 2. Update REACT_APP_API_URL with your backend URL
# 3. The .env file is in .gitignore and won't be pushed to GitHub
# 4. For deployment, Render will automatically set this from render.yaml
