[Unit]
Description=IndicTrans2 Translation Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/indictrans2_server
ExecStart=/home/ubuntu/indictrans2_server/venv/bin/uvicorn server:app --host 0.0.0.0 --port 5001 --workers 1
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
